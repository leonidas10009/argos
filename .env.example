# Proxies (uno por linea, formato http://user:pass@host:port)
PROXY_LIST=

# Browser Pool
BROWSER_POOL_MIN=1
BROWSER_POOL_MAX=3
BROWSER_IDLE_TIMEOUT_MS=60000

# Estrategias activas (csv: cheerio,iframe,puppeteer)
STRATEGIES=cheerio,iframe,puppeteer

# Headless mode
HEADLESS=true

# Stealth mode
STEALTH=true

# Resource blocking (imagenes, fuentes, etc)
BLOCK_RESOURCES=true

# Retry
MAX_RETRIES=3
RETRY_DELAY_MS=1000

# Timeouts
PAGE_TIMEOUT_MS=30000
GLOBAL_TIMEOUT_MS=120000

# Screenshots
SCREENSHOT_ON_ERROR=true
SCREENSHOT_DIR=./screenshots

# Concurrencia
MAX_CONCURRENT=3

# Log level: trace, debug, info, warn, error, fatal
LOG_LEVEL=info

# Circuit Breaker
CB_FAILURE_THRESHOLD=5
CB_RESET_TIMEOUT_MS=300000
CB_HALF_OPEN_MAX=2

# Memory Watchdog (heap monitoring)
MW_ENABLED=true
MW_WARNING_PERCENT=70
MW_CRITICAL_PERCENT=90
MW_CHECK_INTERVAL_MS=30000

# Stream deadline (ms) - devuelve resultados parciales si se excede
STREAM_DEADLINE_MS=45000

# Chrome path (opcional, auto-detecta)
# CHROME_PATH=C:\Program Files\Google\Chrome\Application\chrome.exe
